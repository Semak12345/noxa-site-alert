# Core watcher config
WATCH_URL=https://noxa.fi/
WATCH_MODE=dom
POLL_INTERVAL_MS=10000
REQUEST_TIMEOUT_MS=15000
SEND_STARTUP_PING=false
STATE_DIR=.data
ENV_DISCOVERY=true

# Telegram delivery
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
TELEGRAM_BROADCAST_SUBSCRIBERS=true

# Optional false-positive tuning
# Separate multiple regex rules with || or new lines.
IGNORE_HTML_REGEX=
IGNORE_TEXT_REGEX=
